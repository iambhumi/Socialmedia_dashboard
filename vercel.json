{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "envPrefix": "VITE_",
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.12"
    }
  },
  "env": [
    {
      "key": "GEMINI_API_KEY",
      "value": "@gemini_api_key"
    },
    {
      "key": "RAPIDAPI_KEY",
      "value": "@rapidapi_key"
    }
  ]
}